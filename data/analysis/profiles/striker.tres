[gd_resource type="Resource" script_class="BuildProfile" format=3 uid="uid://build_profile_striker"]

[ext_resource type="Script" path="res://data/analysis/BuildProfile.gd" id="1_striker"]

[resource]
script = ExtResource("1_striker")
id = &"striker"
display_name = "Striker"
description = "Fuerza y velocidad. Golpea rápido, golpea fuerte."
required_high_stats = [&"fuerza", &"velocidad", &"intel_combate"]
penalized_stats = [&"ki", &"poder_ki"]
threshold_high = 0.7
profile_color = Color(0.9, 0.2, 0.1, 1.0)
icon_id = &"striker"
