[gd_resource type="Resource" script_class="NpcEncounterAction" format=3]

[ext_resource type="Script" path="res://data/characters/events/NpcEncounterAction.gd" id="1"]
[ext_resource type="Script" path="res://data/characters/events/NpcEncounterOutcome.gd" id="2"]
[ext_resource type="Script" path="res://data/characters/actions/conditions/ActionCondition.gd" id="3"]

; Condición 1: sobreviviste a Raditz (checkpoint 25)
[sub_resource type="Resource" id="cond_raditz"]
script  = ExtResource("3")
type    = 1
flag_id = &"survived_raditz"

; Condición 2: velocidad >= 30 (mínimo para trepar)
[sub_resource type="Resource" id="cond_vel"]
script      = ExtResource("3")
type        = 3
stat_id     = &"velocidad"
value_float = 30.0

; Outcome 1: Alcanzás a Karin (alta velocidad)
[sub_resource type="Resource" id="outcome_caught"]
script        = ExtResource("2")
narrative_key = &"npc.karin.caught"
description   = "Después de horas de persecución por la torre, finalmente atrapás al gato. Karin suelta una pequeña risa. 'Pocos llegan tan lejos tan rápido.'"
weight        = 2.0
stat_changes  = {&"velocidad": 2.0, &"ki": 1.0}
xp_gained     = 60.0
flags_to_set  = [&"npc_known_karin", &"karin_tower_climbed"]

; Outcome 2: Karin te deja subir pero no lo atrapás todavía
[sub_resource type="Resource" id="outcome_partial"]
script        = ExtResource("2")
narrative_key = &"npc.karin.partial"
description   = "Llegás a la cima exhausto, pero Karin se escapa en el último momento. 'Vuelve cuando seas más rápido.'"
weight        = 2.0
stat_changes  = {&"velocidad": 1.0, &"vitalidad": 1.0, &"resistencia": 0.5}
xp_gained     = 30.0
flags_to_set  = [&"npc_known_karin"]

; Outcome 3: Caída — no llegaste a la cima
[sub_resource type="Resource" id="outcome_fall"]
script        = ExtResource("2")
narrative_key = &"npc.karin.fall"
description   = "Caés a mitad de la torre. El golpe duele, pero algo en ti se endurece con la caída."
weight        = 1.0
stat_changes  = {&"resistencia": 1.5, &"vitalidad": -1.0}
xp_gained     = 15.0
flags_to_set  = []

[resource]
script           = ExtResource("1")
id               = &"encounter_karin_tower"
display_name     = "Trepar la Torre de Karin"
action_type      = &"event"
display_category = &"event"
unlock_day       = 25
requires_unlock_flag = &""
selection_weight = 1.8
conditions       = [SubResource("cond_raditz"), SubResource("cond_vel")]
npc_id           = &"karin"
npc_name         = "Karin-sama"
completion_flag  = &"karin_tower_climbed"
outcomes         = [SubResource("outcome_caught"), SubResource("outcome_partial"), SubResource("outcome_fall")]
