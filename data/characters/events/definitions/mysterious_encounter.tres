[gd_resource type="Resource" script_class="EventAction" format=3 uid="uid://mysterious_encounter"]

[ext_resource type="Script" path="res://data/characters/events/EventAction.gd" id="1_ev"]
[ext_resource type="Script" path="res://data/characters/actions/EventOutcome.gd" id="2_out"]

[sub_resource type="Resource" id="out_teaching"]
script = ExtResource("2_out")
narrative_key = "event.encounter.teaching"
weight = 2.0
stat_changes = {&"strength": 0.5, &"speed": 0.5, &"ki_max": 0.5}
xp_gained = 50.0
extra_data = {}

[sub_resource type="Resource" id="out_mental"]
script = ExtResource("2_out")
narrative_key = "event.encounter.mental_challenge"
weight = 2.0
stat_changes = {&"ki_max": 2.0, &"speed": -0.5}
xp_gained = 30.0
extra_data = {}

[sub_resource type="Resource" id="out_illusion"]
script = ExtResource("2_out")
narrative_key = "event.encounter.illusion"
weight = 1.0
stat_changes = {}
xp_gained = 10.0
extra_data = {}

[resource]
script = ExtResource("1_ev")
id = &"mysterious_encounter"
display_name = "Encuentro misterioso"
description = "Un anciano guerrero observa tu entrenamiento en silencio. ¿Qué querrá?"
action_type = &"event"
unlock_day = 10
requires_unlock_flag = &""
selection_weight = 0.6
outcomes = [SubResource("out_teaching"), SubResource("out_mental"), SubResource("out_illusion")]
