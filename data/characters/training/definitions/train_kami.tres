[gd_resource type="Resource" script_class="TrainingAction" format=3]

[ext_resource type="Script" path="res://data/characters/training/TrainingAction.gd" id="1"]
[ext_resource type="Script" path="res://data/characters/actions/conditions/ActionCondition.gd" id="2"]

[sub_resource type="Resource" id="cond_tournament"]
script = ExtResource("2")
type = 1
flag_id = &"arc_tournament"

[sub_resource type="Resource" id="cond_ki"]
script = ExtResource("2")
type = 3
stat_id = &"ki"
value_float = 20.0

[resource]
script = ExtResource("1")
id = &"train_kami"
display_name = "Entrenamiento con Kami-sama"
action_type = &"training"
unlock_day = 40
requires_unlock_flag = &""
selection_weight = 1.3
conditions = [SubResource("cond_tournament"), SubResource("cond_ki")]
target_stats = [&"ki", &"poder_ki", &"inteligencia"]
scale_stat_id = &"ki"
scale_threshold = 80.0
scale_max_bonus = 0.5
base_gain = 1.8
energy_cost = 1
