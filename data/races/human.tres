&"velocidad":     1.0,
&"ki":            1.1,
&"vitalidad":     1.0,
&"resistencia":   1.0,
&"poder_ki":      1.0,
&"inteligencia":  1.2,
&"intel_combate": 1.1
}
racial_traits = [&"fast_learner", &"iron_will"]
